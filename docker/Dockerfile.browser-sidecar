# syntax=docker/dockerfile:1.7

FROM rust:1.94-slim-trixie AS chef

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/usr/local/cargo/registry \
    cargo install cargo-chef

FROM chef AS planner
WORKDIR /app
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
WORKDIR /app

COPY --from=planner /app/recipe.json recipe.json
RUN --mount=type=cache,target=/app/target \
    --mount=type=cache,target=/usr/local/cargo/registry \
    cargo chef cook --release -p oxide-browser-sidecar --recipe-path recipe.json

COPY . .
RUN --mount=type=cache,target=/app/target \
    --mount=type=cache,target=/usr/local/cargo/registry \
    set -eux; \
    cargo build --release -p oxide-browser-sidecar; \
    mkdir -p /runtime/bin; \
    cp /app/target/release/oxide-browser-sidecar /runtime/bin/

FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    chromium \
    curl \
    libssl3 \
    tini \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --system --gid 10002 browser \
    && useradd --system --uid 10002 --gid 10002 --create-home --home-dir /home/browser browser \
    && mkdir -p /var/lib/oxide-browser/artifacts \
    && chown -R browser:browser /var/lib/oxide-browser /home/browser

COPY --from=builder /runtime/bin/oxide-browser-sidecar /usr/local/bin/oxide-browser-sidecar

ENV BROWSER_AGENT_SIDECAR_BIND=0.0.0.0:8787 \
    BROWSER_AGENT_ARTIFACT_DIR=/var/lib/oxide-browser/artifacts \
    CHROMIUM_BIN=/usr/bin/chromium

USER browser
WORKDIR /home/browser

EXPOSE 8787

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/usr/local/bin/oxide-browser-sidecar"]
