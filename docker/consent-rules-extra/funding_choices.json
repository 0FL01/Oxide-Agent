{
    "FundingChoices": {
        "detectors": [
            {
                "presentMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": ".fc-consent-root"
                        }
                    }
                ],
                "showingMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": ".fc-consent-root .fc-cookie-banner",
                            "displayFilter": true
                        }
                    }
                ]
            }
        ],
        "methods": [
            {
                "action": {
                    "type": "hide",
                    "target": {
                        "selector": ".fc-consent-root"
                    }
                },
                "name": "HIDE_CMP"
            },
            {
                "action": {
                    "type": "click",
                    "target": {
                        "selector": ".fc-consent-root button.fc-cta-manage-options"
                    }
                },
                "name": "OPEN_OPTIONS"
            },
            {
                "action": {
                    "type": "ifallownone",
                    "trueAction": {
                        "type": "click",
                        "target": {
                            "selector": ".fc-consent-root .fc-cta-do-not-consent"
                        }
                    },
                    "falseAction": {
                        "type": "list",
                        "actions": [
                            {
                                "type": "foreach",
                                "target": {
                                    "selector": ".fc-consent-root .fc-preference-container"
                                },
                                "action": {
                                    "type": "consent",
                                    "consents": [
                                        {
                                            "matcher": {
                                                "type": "css",
                                                "target": {
                                                    "selector": ".fc-slider-el[aria-checked='true']"
                                                }
                                            },
                                            "toggleAction": {
                                                "type": "click",
                                                "target": {
                                                    "selector": ".fc-slider-el"
                                                }
                                            },
                                            "type": "F"
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                },
                "name": "DO_CONSENT"
            },
            {
                "action": {
                    "type": "click",
                    "target": {
                        "selector": ".fc-consent-root button.fc-confirm-choices"
                    }
                },
                "name": "SAVE_CONSENT"
            },
            {
                "name": "UTILITY"
            }
        ]
    }
}
