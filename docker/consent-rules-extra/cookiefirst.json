{
    "CookieFirst": {
        "detectors": [
            {
                "presentMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": "#cookiefirst-root, .cookiefirst-root"
                        }
                    }
                ],
                "showingMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": "#cookiefirst-root, .cookiefirst-root",
                            "displayFilter": true
                        }
                    }
                ]
            }
        ],
        "methods": [
            {
                "action": {
                    "type": "hide",
                    "target": {
                        "selector": "#cookiefirst-root"
                    }
                },
                "name": "HIDE_CMP"
            },
            {
                "action": {
                    "type": "click",
                    "target": {
                        "selector": ".cookiefirst-root button[data-cookiefirst-action='preferences']"
                    }
                },
                "name": "OPEN_OPTIONS"
            },
            {
                "action": {
                    "type": "ifallownone",
                    "trueAction": {
                        "type": "click",
                        "target": {
                            "selector": ".cookiefirst-root button[data-cookiefirst-action='reject']"
                        }
                    },
                    "falseAction": {
                        "type": "click",
                        "target": {
                            "selector": ".cookiefirst-root button[data-cookiefirst-action='accept']"
                        }
                    }
                },
                "name": "DO_CONSENT"
            },
            {
                "action": {
                    "type": "click",
                    "target": {
                        "selector": ".cookiefirst-root button[data-cookiefirst-action='save']"
                    }
                },
                "name": "SAVE_CONSENT"
            },
            {
                "name": "UTILITY"
            }
        ]
    }
}
