{
    "CookieHub": {
        "detectors": [
            {
                "presentMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": ".ch2-dialog"
                        }
                    }
                ],
                "showingMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": ".ch2-dialog",
                            "displayFilter": true
                        }
                    }
                ]
            }
        ],
        "methods": [
            {
                "action": {
                    "type": "hide",
                    "target": {
                        "selector": ".ch2-dialog"
                    }
                },
                "name": "HIDE_CMP"
            },
            {
                "name": "OPEN_OPTIONS"
            },
            {
                "action": {
                    "type": "ifallownone",
                    "trueAction": {
                        "type": "click",
                        "target": {
                            "selector": ".ch2-dialog-actions button.ch2-deny-all-btn"
                        }
                    },
                    "falseAction": {
                        "type": "click",
                        "target": {
                            "selector": ".ch2-dialog-actions button.ch2-allow-all-btn"
                        }
                    }
                },
                "name": "DO_CONSENT"
            },
            {
                "name": "SAVE_CONSENT"
            },
            {
                "name": "UTILITY"
            }
        ]
    }
}
