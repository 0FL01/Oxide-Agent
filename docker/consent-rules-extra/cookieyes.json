{
    "CookieYes": {
        "detectors": [
            {
                "presentMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": ".cky-consent-container"
                        }
                    }
                ],
                "showingMatcher": [
                    {
                        "type": "css",
                        "target": {
                            "selector": ".cky-consent-container",
                            "displayFilter": true
                        }
                    }
                ]
            }
        ],
        "methods": [
            {
                "action": {
                    "type": "list",
                    "actions": [
                        {
                            "type": "hide",
                            "target": {
                                "selector": ".cky-modal"
                            }
                        },
                        {
                            "type": "hide",
                            "target": {
                                "selector": ".cky-overlay"
                            },
                            "forceHide": true
                        }
                    ]
                },
                "name": "HIDE_CMP"
            },
            {
                "action": {
                    "type": "click",
                    "target": {
                        "selector": ".cky-btn-customize"
                    }
                },
                "name": "OPEN_OPTIONS"
            },
            {
                "action": {
                    "type": "ifallownone",
                    "trueAction": {
                        "type": "click",
                        "target": {
                            "selector": ".cky-btn-reject"
                        }
                    },
                    "falseAction": {
                        "type": "ifallowall",
                        "trueAction": {
                            "type": "click",
                            "target": {
                                "selector": ".cky-btn-accept"
                            }
                        },
                        "falseAction": {
                            "type": "list",
                            "actions": [
                                {
                                    "type": "consent",
                                    "consents": [
                                        {
                                            "matcher": {
                                                "type": "checkbox",
                                                "target": {
                                                    "selector": "#ckySwitchfunctional"
                                                }
                                            },
                                            "toggleAction": {
                                                "type": "click",
                                                "target": {
                                                    "selector": "#ckySwitchfunctional"
                                                }
                                            },
                                            "type": "A"
                                        }
                                    ]
                                },
                                {
                                    "type": "consent",
                                    "consents": [
                                        {
                                            "matcher": {
                                                "type": "checkbox",
                                                "target": {
                                                    "selector": "#ckySwitchanalytics"
                                                }
                                            },
                                            "toggleAction": {
                                                "type": "click",
                                                "target": {
                                                    "selector": "#ckySwitchanalytics"
                                                }
                                            },
                                            "type": "B"
                                        },
                                        {
                                            "matcher": {
                                                "type": "checkbox",
                                                "target": {
                                                    "selector": "#ckySwitchperformance"
                                                }
                                            },
                                            "toggleAction": {
                                                "type": "click",
                                                "target": {
                                                    "selector": "#ckySwitchperformance"
                                                }
                                            },
                                            "type": "B"
                                        }
                                    ]
                                },
                                {
                                    "type": "consent",
                                    "consents": [
                                        {
                                            "matcher": {
                                                "type": "checkbox",
                                                "target": {
                                                    "selector": "#ckySwitchadvertisement"
                                                }
                                            },
                                            "toggleAction": {
                                                "type": "click",
                                                "target": {
                                                    "selector": "#ckySwitchadvertisement"
                                                }
                                            },
                                            "type": "F"
                                        }
                                    ]
                                },
                                {
                                    "type": "consent",
                                    "consents": [
                                        {
                                            "matcher": {
                                                "type": "checkbox",
                                                "target": {
                                                    "selector": "#ckySwitchother"
                                                }
                                            },
                                            "toggleAction": {
                                                "type": "click",
                                                "target": {
                                                    "selector": "#ckySwitchother"
                                                }
                                            },
                                            "type": "X"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                },
                "name": "DO_CONSENT"
            },
            {
                "action": {
                    "type": "click",
                    "target": {
                        "selector": ".cky-btn-preferences"
                    }
                },
                "name": "SAVE_CONSENT"
            },
            {
                "name": "UTILITY"
            }
        ]
    }
}
