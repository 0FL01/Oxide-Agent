# Telegram
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ALLOWED_USERS=123456789,987654321
AGENT_ACCESS_IDS=123456789 # ID users with access to agent
MANAGER_ALLOWED_USERS=123456789 # ID users allowed to use manager control-plane tools (create/edit forum topics, manage bindings, etc.)

# Cloudflare R2 Storage 
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name
R2_REGION=auto  # Region for S3-compatible storage. Use "auto" for Cloudflare R2 (global).
                # For MinIO/Wasabi/Backblaze B2, set region like "us-east-1" or "eu-west-1".

# API Keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
ZAI_API_KEY=YOUR_ZAI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Logging
RUST_LOG=oxide_agent=info,zai_rs=debug,hyper=warn,h2=error,reqwest=warn,tokio=warn,tower=warn,async_openai=warn
# Включить verbose режим (раскомментировать для отладки):
# DEBUG_MODE=true

# Optional web search providers (can be enabled together)
# TAVILY_ENABLED=true
TAVILY_API_KEY=YOUR_TAVILY_API_KEY # Optional: Tavily API key for hosted web search
# SEARXNG_ENABLED=true
# SEARXNG_URL=http://127.0.0.1:8081
# SEARXNG_TIMEOUT_SECS=30
# CRAWL4AI_ENABLED=true
# CRAWL4AI_URL=http://127.0.0.1:11235
# CRAWL4AI_TIMEOUT_SECS=120
# Browser Use (disabled: requires a quality vision-capable agent model at a reasonable price-per-token)
# BROWSER_USE_URL=http://127.0.0.1:8002
# BROWSER_USE_TIMEOUT_SECS=300
# BROWSER_USE_MAX_CONCURRENT=2
# BROWSER_USE_BRIDGE_MAX_PROFILES_PER_SCOPE=3
# BROWSER_USE_BRIDGE_PROFILE_IDLE_TTL_SECS=604800
# BROWSER_USE_BRIDGE_BROWSER_READY_RETRIES=2
# BROWSER_USE_BRIDGE_BROWSER_READY_RETRY_DELAY_MS=750
# BROWSER_USE_MODEL_ID="GLM-4.6V" # Browser Use dedicated route (docker-compose default)
# BROWSER_USE_MODEL_PROVIDER="zai" # Browser Use dedicated provider (docker-compose default)
# BROWSER_USE_BRIDGE_LLM_PROVIDER=google # Legacy browser_use sidecar fallback
# BROWSER_USE_BRIDGE_LLM_MODEL=gemini-2.5-flash

# Agent loop and loop detection settings
LOOP_DETECTION_ENABLED=true
AGENT_MAX_ITERATIONS=200
SUB_AGENT_MAX_ITERATIONS=60
AGENT_SEARCH_LIMIT=10
LOOP_TOOL_CALL_THRESHOLD=5
LOOP_CONTENT_CHUNK_SIZE=50
LOOP_CONTENT_THRESHOLD=10
LOOP_MAX_HISTORY_LENGTH=5000
LOOP_LLM_CHECK_AFTER_TURNS=30
LOOP_LLM_CHECK_INTERVAL=3
LOOP_LLM_CONFIDENCE_THRESHOLD=0.9
LOOP_LLM_HISTORY_COUNT=20
LOOP_SCOUT_MODEL=labs-devstral-small-2512
SKILL_TOKEN_BUDGET=4096

# Optional settings
# SYSTEM_MESSAGE="Your custom system prompt"
# GOFILE_TOKEN=your_gofile_token # Optional: GoFile account token for upload_file

# Jira MCP Configuration (requires 'jira' feature enabled)
# Uncomment to enable Jira integration via MCP protocol
# Binary path is auto-detected: checks JIRA_MCP_BINARY_PATH, then /usr/local/bin/jira-mcp,
# then /usr/bin/jira-mcp, finally falls back to 'jira-mcp' (searches in PATH)
# JIRA_MCP_BINARY_PATH=/usr/local/bin/jira-mcp  # Optional: explicit binary path
# JIRA_URL=https://jira.company.com             # Required: Jira Server 7.5.0 base URL
# JIRA_EMAIL=agent@company.com                  # Required: Jira user email/username
# JIRA_API_TOKEN=your_api_token                 # Required: Jira API token or password
# 
# Note: Jira tools are disabled by default even when configured.
# Enable via manager agent: topic_agent_tools_enable with tools=["jira"]

# Mattermost MCP Configuration (requires 'mattermost' feature enabled)
# Binary path is auto-detected: checks MATTERMOST_MCP_BINARY_PATH, then /usr/local/bin/mattermost-mcp,
# /usr/bin/mattermost-mcp, /usr/local/bin/mcp-server-mattermost, /usr/bin/mcp-server-mattermost,
# and finally falls back to 'mattermost-mcp' in PATH.
# MATTERMOST_MCP_BINARY_PATH=/usr/local/bin/mattermost-mcp  # Optional: explicit binary path
# MATTERMOST_URL=https://mattermost.company.com             # Required: Mattermost base URL
# MATTERMOST_TOKEN=your_bot_or_user_token                   # Required: Mattermost bot or user token
# MATTERMOST_TIMEOUT=30                                     # Optional: upstream request timeout in seconds
# MATTERMOST_MAX_RETRIES=3                                  # Optional: upstream retry count
# MATTERMOST_VERIFY_SSL=true                                # Optional: verify TLS certificates
#
# Note: Mattermost tools are disabled by default even when configured.
# Enable via manager agent: topic_agent_tools_enable with tools=["mattermost"]

# DM (Direct Message) Tool Restrictions
# These tools are blocked by default in private/DM chats but available in forum topics:
# - SSH tools: ssh_exec, ssh_sudo_exec, ssh_read_file, ssh_apply_file_edit, ssh_check_process
# - Jira tools: jira_read, jira_write, jira_schema
# - Mattermost tools: all mattermost_* tools
#
# Admin override via allowlist mode (only these tools will be allowed in DM):
# DM_ALLOWED_TOOLS=todos_write,todos_list,delegate_to_sub_agent
#
# Admin override via additional blocklist (adds to default DM restrictions):
# DM_BLOCKED_TOOLS=sandbox_exec

# --- Dynamic Model Configuration ---
# Declare the models you want to expose. The "Change Model" menu and multimodal handlers only know about the names you list here.

# 1. Chat model (multimodal recommended)
CHAT_MODEL_ID="google/gemini-3-flash-preview"
CHAT_MODEL_PROVIDER="openrouter"
CHAT_MODEL_NAME="✨ Gemini 3.0 Flash"

# Alternative chat example (Mistral)
#CHAT_MODEL_ID="mistral-large-latest"
#CHAT_MODEL_PROVIDER="mistral"
#CHAT_MODEL_NAME="Mistral Large Chat"
#CHAT_MODEL_MAX_OUTPUT_TOKENS=64000
#CHAT_MODEL_CONTEXT_WINDOW_TOKENS=64000

# 2. Agent model
# Primary route stays sticky; fallback activates only after persistent 429s.
# Priority example: MiniMax > ZAI > Mistral
AGENT_MODEL_ID="MiniMax-M2.7"
AGENT_MODEL_PROVIDER="minimax"
AGENT_MODEL_MAX_OUTPUT_TOKENS=32000
AGENT_MODEL_CONTEXT_WINDOW_TOKENS=204800

# Optional sub-agent override
SUB_AGENT_MODEL_ID="MiniMax-M2.7"
SUB_AGENT_MODEL_PROVIDER="minimax"
SUB_AGENT_MAX_OUTPUT_TOKENS=32000
SUB_AGENT_CONTEXT_WINDOW_TOKENS=204800

# Weighted failover routes for main agent (.env only, no YAML required)
# NVIDIA NIM is safe here only with tool-calling-capable models; unsupported NIM routes
# are skipped automatically during tool-enabled agent execution.
AGENT_MODEL_ROUTES__0__ID="MiniMax-M2.7"
AGENT_MODEL_ROUTES__0__PROVIDER="minimax"
AGENT_MODEL_ROUTES__0__MAX_OUTPUT_TOKENS=32000
AGENT_MODEL_ROUTES__0__CONTEXT_WINDOW_TOKENS=204800
AGENT_MODEL_ROUTES__0__WEIGHT=10

AGENT_MODEL_ROUTES__1__ID="glm-4.7"
AGENT_MODEL_ROUTES__1__PROVIDER="zai"
AGENT_MODEL_ROUTES__1__MAX_OUTPUT_TOKENS=32000
AGENT_MODEL_ROUTES__1__CONTEXT_WINDOW_TOKENS=200000
AGENT_MODEL_ROUTES__1__WEIGHT=5

AGENT_MODEL_ROUTES__2__ID="mistral-small-2603"
AGENT_MODEL_ROUTES__2__PROVIDER="mistral"
AGENT_MODEL_ROUTES__2__MAX_OUTPUT_TOKENS=32000
AGENT_MODEL_ROUTES__2__CONTEXT_WINDOW_TOKENS=200000
AGENT_MODEL_ROUTES__2__WEIGHT=2

# Example NVIDIA NIM route kept behind a proven backup
#AGENT_MODEL_ROUTES__3__ID="meta/llama-3.1-70b-instruct"
#AGENT_MODEL_ROUTES__3__PROVIDER="nvidia"
#AGENT_MODEL_ROUTES__3__MAX_OUTPUT_TOKENS=32000
#AGENT_MODEL_ROUTES__3__CONTEXT_WINDOW_TOKENS=128000
#AGENT_MODEL_ROUTES__3__WEIGHT=3

# Weighted failover routes for sub-agent
SUB_AGENT_MODEL_ROUTES__0__ID="MiniMax-M2.7"
SUB_AGENT_MODEL_ROUTES__0__PROVIDER="minimax"
SUB_AGENT_MODEL_ROUTES__0__MAX_OUTPUT_TOKENS=32000
SUB_AGENT_MODEL_ROUTES__0__CONTEXT_WINDOW_TOKENS=204800
SUB_AGENT_MODEL_ROUTES__0__WEIGHT=10

SUB_AGENT_MODEL_ROUTES__1__ID="glm-4.7"
SUB_AGENT_MODEL_ROUTES__1__PROVIDER="zai"
SUB_AGENT_MODEL_ROUTES__1__MAX_OUTPUT_TOKENS=32000
SUB_AGENT_MODEL_ROUTES__1__CONTEXT_WINDOW_TOKENS=200000
SUB_AGENT_MODEL_ROUTES__1__WEIGHT=5

SUB_AGENT_MODEL_ROUTES__2__ID="mistral-large-2512"
SUB_AGENT_MODEL_ROUTES__2__PROVIDER="mistral"
SUB_AGENT_MODEL_ROUTES__2__MAX_OUTPUT_TOKENS=32000
SUB_AGENT_MODEL_ROUTES__2__CONTEXT_WINDOW_TOKENS=200000
SUB_AGENT_MODEL_ROUTES__2__WEIGHT=2

# Single-provider alternatives if you do not want failover routing
#AGENT_MODEL_ID="glm-4.7"
#AGENT_MODEL_PROVIDER="zai"
#AGENT_MODEL_MAX_OUTPUT_TOKENS=32000
#AGENT_MODEL_CONTEXT_WINDOW_TOKENS=200000
#SUB_AGENT_MODEL_ID="glm-4.7"
#SUB_AGENT_MODEL_PROVIDER="zai"
#SUB_AGENT_MAX_OUTPUT_TOKENS=32000
#SUB_AGENT_CONTEXT_WINDOW_TOKENS=200000

# 3. Media model (used for voice/image fallbacks)
# For transcription, you can use Mistral Voxtral models:
# - voxtral-mini-latest (recommended, alias to current version)
# - voxtral-mini-transcribe-26-02 (batch transcription)
# Note: voxtral-mini-realtime-26-02 is NOT supported (realtime streaming is incompatible)
# Example: MEDIA_MODEL_ID="voxtral-mini-latest" MEDIA_MODEL_PROVIDER="mistral"
MEDIA_MODEL_ID="google/gemini-3-flash-preview"
MEDIA_MODEL_PROVIDER="openrouter"

# 4. Narrator model (status/frontier summarizer)
NARRATOR_MODEL_ID="labs-mistral-small-creative"
NARRATOR_MODEL_PROVIDER="mistral"

# 5. Compaction model for Agent Mode context compression
# Optional but recommended. If unset, the staged compaction pipeline still works
# and falls back to a deterministic summary when LLM compaction is needed.
COMPACTION_MODEL_ID="glm-4.5-air"
COMPACTION_MODEL_PROVIDER="zai"
COMPACTION_MODEL_MAX_OUTPUT_TOKENS=512
COMPACTION_MODEL_TIMEOUT_SECS=20

# Compaction tool-window protection: token budget reserved for recent tool outputs
# in hot memory. Tool results within this budget are protected from pruning during
# active runs. On glm-4.7 (200k window) this is additionally capped at window/5.
# Bump to 12k-16k for heavy DevOps/research workflows with many SSH or search calls.
COMPACTION_PROTECTED_TOOL_WINDOW_TOKENS=8192

# Hot-context warning/compaction thresholds.
# These control Stage 5 soft warning and hard compaction limits.
SOFT_WARNING_TOKENS=60000
HARD_COMPACTION_TOKENS=80000

# Internal hot-context budgets are clamped separately from model context windows:
# - main agent clamp cap: 200000 tokens
# - sub-agent clamp cap: 64000 tokens
#
# Staged Agent Mode compaction thresholds are currently fixed in code:
# warning 65%, prune 75%, compact 85%, over-limit 95% of the effective window.

# --- Embeddings Configuration (for Skills System) ---

# Option 1: Mistral embeddings
# EMBEDDING_PROVIDER=mistral
# EMBEDDING_MODEL_ID=codestral-embed

# Option 2: OpenRouter embeddings
# EMBEDDING_PROVIDER=openrouter
# EMBEDDING_MODEL_ID=thenlper/gte-base

# --- Persistent Memory (Postgres + pgvector) ---
# Canonical production backend for typed durable memory retrieval/write path.
MEMORY_DATABASE_URL=postgres://oxide_agent:change_me@127.0.0.1:5432/oxide_agent
MEMORY_DATABASE_MAX_CONNECTIONS=5
MEMORY_DATABASE_AUTO_MIGRATE=true

# --- Kokoro TTS (text-to-speech, voice messages) ---
#
# Kokoro TTS server URL. Defaults to http://127.0.0.1:8000 if not set.
# Set to empty string to disable the text_to_speech_en tool entirely.
# KOKORO_TTS_URL=http://127.0.0.1:8000
# KOKORO_TTS_VOICE=af_heart       # af_bella | af_aoede | af_alloy | af_heart (default)
# KOKORO_TTS_FORMAT=ogg           # ogg (recommended for Telegram) | mp3 | wav
# KOKORO_TTS_TIMEOUT_SECS=60

# --- Silero TTS (Russian text-to-speech, voice messages) ---
#
# Silero TTS server URL. Defaults to http://127.0.0.1:8001 if not set.
# Set to empty string to disable the text_to_speech_ru tool entirely.
# SILERO_TTS_URL=http://127.0.0.1:8001
# SILERO_TTS_SPEAKER=baya         # aidar | baya (default) | kseniya | xenia
# SILERO_TTS_FORMAT=ogg           # ogg (recommended for Telegram) | wav
# SILERO_TTS_SAMPLE_RATE=48000    # 8000 | 24000 | 48000 (default, best quality)
# SILERO_TTS_TIMEOUT_SECS=60

# --- Topic Routing & Dynamic Bindings ---
#
# Manager home: the designated forum topic that serves as the control plane for this bot.
# When MANAGER_HOME_CHAT_ID is set:
#   - Manager control-plane tools (forum_topic_create, topic_binding_set, etc.) are
#     available only in this chat + thread combination.
#   - The topic implicitly receives a static route to MANAGER_HOME_AGENT_ID, so the
#     bot selects that agent profile without needing a YAML topicConfigs entry.
#   - MANAGER_HOME_THREAD_ID defaults to 1 (Telegram General topic).
#   - MANAGER_HOME_AGENT_ID defaults to "control-plane".
#
# Example: General topic in a Telegram supergroup forum.
# MANAGER_HOME_CHAT_ID=-1001234567890
# MANAGER_HOME_THREAD_ID=1
# MANAGER_HOME_AGENT_ID=control-plane
#
# NOTE: Per-topic routing for non-home topics (e.g. support topics) still uses YAML
# topicConfigs. The manager home env vars cover only the designated control-plane topic.
#
# telegram:
#   topicConfigs:
#     - chatId: -1001234567890
#       threadId: 42
#       enabled: true
#       requireMention: false
#       agentId: "support-agent"
#       systemPrompt: "You are a helpful support assistant"
#       skills: []
#
# Features:
# - Manager Control-Plane: Users listed in MANAGER_ALLOWED_USERS can create/edit forum topics,
#   manage topic bindings, and access audit logs via manager_* tools. If
#   MANAGER_HOME_CHAT_ID is configured, these tools are available only in that home topic.
# - Topic Routing: Bot can be configured to respond only in specific Telegram forum topics,
#   with optional mention requirements and custom system prompts per topic.
# - Dynamic Bindings: Runtime bindings allow temporary association of agents with topics
#   (e.g., for ad-hoc support threads) that override static configuration and expire after
#   a set period or inactivity.
