FROM debian:trixie-slim

# Install system packages including ffmpeg and Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    jq \
    git \
    ca-certificates \
    dnsutils \
    iputils-ping \
    procps \
    net-tools \
    unzip \
    zip \
    ffmpeg \
    python3 \
    python3-pip \
    tzdata \
    traceroute \
    telnet \
    whois \
    nmap \
    mtr \
    && rm -rf /var/lib/apt/lists/*

# Set timezone to Europe/Moscow
RUN ln -snf /usr/share/zoneinfo/Europe/Moscow /etc/localtime && \
    echo "Europe/Moscow" > /etc/timezone

# Install yt-dlp (latest version via pip)
RUN pip install --no-cache-dir --break-system-packages yt-dlp

# Install common Python packages
RUN pip install --no-cache-dir --break-system-packages \
    requests \
    httpx \
    beautifulsoup4 \
    lxml

# Create workspace directory
WORKDIR /workspace

# Keep container alive
CMD ["sleep", "infinity"]
